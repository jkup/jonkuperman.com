<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-36ERW4KTTP"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-36ERW4KTTP');
    </script>

    <script>
      (function(){var t=localStorage.getItem("theme")||(matchMedia("(prefers-color-scheme:dark)").matches?"dark":"light");document.documentElement.dataset.theme=t})();
    </script>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/img/favicon.ico" type="image/png">

    <title>{{ title or metadata.title }}</title>
    <meta name="description" content="{{ description or metadata.description }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ '/css/index.css' | url }}">
    <link rel="alternate" href="{{ metadata.feed.path | url }}" type="application/atom+xml" title="{{ metadata.title }}">
    <link rel="alternate" href="{{ metadata.jsonfeed.path | url }}" type="application/json" title="{{ metadata.title }}">

    <meta property="og:title" content="{{ title or renderData.title or metadata.title | safe }}"/>
    <meta property="og:url" content="{{ page.url }}" />
    <meta property="og:description" content="{{ description or renderData.description | safe }}" />
    <meta property="og:type" content="article" />
    <meta property="og:image" content="https://jonkuperman.com{{ image | safe or "/img/og-image.png"}}" />
    <meta name="twitter:card" content="summary_large_image"></meta>
    <meta name="twitter:creator" content="@jkup"></meta>
  </head>
  <body>
    <header class="Layout--header">
      <div class="navigation">
        <div class="navigation__inner">
          <a href="/" class="navigation__logo">jk<span class="navigation__logo-dot">.</span></a>
          <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
          <nav>
            <ul>
              <li><a href="/blog/"{% if page.url and "/blog/" in page.url %} class="active"{% endif %}>Writing</a></li>
              <li><a href="/about/"{% if page.url == "/about/" %} class="active"{% endif %}>About</a></li>
              <li><a href="/resume/"{% if page.url == "/resume/" %} class="active"{% endif %}>Resume</a></li>
              <li>
                <button class="theme-toggle" aria-pressed="false">
                  <svg fill="currentColor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.758 17.303a.75.75 0 0 0-1.061-1.06l-1.591 1.59a.75.75 0 0 0 1.06 1.061l1.591-1.59ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.697 7.757a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 0 0-1.061 1.06l1.59 1.591Z" />
                    <path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 0 1 .162.819A8.97 8.97 0 0 0 9 6a9 9 0 0 0 9 9 8.97 8.97 0 0 0 3.463-.69.75.75 0 0 1 .981.98 10.503 10.503 0 0 1-9.694 6.46c-5.799 0-10.5-4.7-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 0 1 .818.162Z" clip-rule="evenodd" />
                  </svg>
                  <span class="sr-only">Toggle Theme</span>
                </button>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <main class="Layout--main">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <a href="/" class="site-footer__logo">jk<span class="navigation__logo-dot">.</span></a>
        <nav class="site-footer__nav">
          <a href="/blog/">Writing</a>
          <a href="/about/">About</a>
          <a href="/resume/">Resume</a>
        </nav>
        <p class="site-footer__copy">&copy; 2026 Jon Kuperman</p>
      </div>
    </footer>

    <script defer src="/scripts/index.js"></script>
  </body>
</html>
